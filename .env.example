# Copy to .env for local dev. Never commit the populated copy.

# Database (Postgres). DIRECT_URL is the non-pooled connection — used for
# migrations and the pg-boss queue (LISTEN/NOTIFY + advisory locks need it).
DATABASE_URL=postgresql://hiredesq:hiredesq@localhost:5434/hiredesq
DIRECT_URL=postgresql://hiredesq:hiredesq@localhost:5434/hiredesq

# Auth
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Sign in with Google (authorization-code popup flow). From the OAuth *Web* client in
# Google Cloud Console. GOOGLE_CLIENT_ID is public (the web app uses the SAME value as
# NEXT_PUBLIC_GOOGLE_CLIENT_ID in apps/web/.env.local); GOOGLE_CLIENT_SECRET is a secret
# (§6) used to exchange the auth code server-side. Add the web origin (e.g.
# http://localhost:8100, https://hiredesq.com) to the client's Authorized JavaScript
# origins. Inert until set: the Google button hides itself and password auth is unaffected.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption key for sensitive PII fields at rest (32-byte base64)
ENCRYPTION_KEY=

# AI provider — CV parsing (Haiku 4.5). See docs/cv-parsing-pipeline.md
ANTHROPIC_API_KEY=

# Embeddings — semantic candidate search (§5). Voyage AI (1024-dim by default).
# Only the candidate's searchable summary is sent — never contact PII (§2). The
# model's output dim must match EMBEDDING_DIM / the vector() column (1024); change
# them together if you switch models. EMBEDDINGS_MODEL + VOYAGE_BASE_URL are optional.
VOYAGER_API_KEY=
EMBEDDINGS_MODEL=voyage-4-lite

# Forwarding inbox (§2A, F9). INBOX_DOMAIN is the address domain (must match the
# Cloudflare Email Routing zone). INBOUND_WEBHOOK_SECRET authenticates the Email
# Worker → POST /inbound/email; set the SAME value as the Worker's secret. See
# deploy/email-worker/README.md.
INBOX_DOMAIN=inbox.hiredesq.com
INBOUND_WEBHOOK_SECRET=

# Stripe billing (§4/§6, F8). STRIPE_TEAM_PRICE_ID is the recurring price for the
# team plan; STRIPE_WEBHOOK_SECRET signs the plan-flip webhook. Inert until set —
# checkout/portal/webhook return a clear error otherwise. APP_URL is the web origin
# used for checkout return URLs. See deploy/STRIPE.md.
STRIPE_SECRET_KEY=
STRIPE_TEAM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
APP_URL=http://localhost:8100

# Transactional email (Resend) — password-reset links (forgot-password flow).
# RESEND_FROM must be a verified sender on your Resend domain. Inert until set:
# forgot-password still returns 204 and (in dev) logs the reset link instead.
RESEND_API_KEY=
RESEND_FROM="Hiredesq <noreply@hiredesq.com>"

# Object storage (S3 / Cloudflare R2) — uploaded resumes.
# Local dev: MinIO (docker-compose) → endpoint http://localhost:9000,
# key/secret hiredesq / hiredesq-dev-secret. Prod: Cloudflare R2.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=hiredesq-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# URLs / ports. Web runs on 8100, API on 8101 (avoids 3000/3001 used by other
# local projects). APP_URL is the web origin the API allows via CORS; PORT is the
# API's listen port. The web reads the API base from apps/web/.env.local
# (NEXT_PUBLIC_API_URL=http://localhost:8101) — Next doesn't load this root .env.
PORT=8101
APP_URL=http://localhost:8100
API_URL=http://localhost:8101
